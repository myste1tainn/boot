" >> setup nerdcomment key bindings
let g:NERDCreateDefaultMappings = 0
let g:NERDSpaceDelims = 1

xnoremap <Leader>ci :call NERDComment('n', 'toggle')<CR>
nnoremap <Leader>ci :call NERDComment('n', 'toggle')<CR>

" Table handles
nnoremap <silent> <A-]> :tabn<CR>
nnoremap <silent> <A-[> :tabp<CR>
noremap <silent> <A-1> :tabfirst<CR>
noremap <silent> <A-2> 2gt
noremap <silent> <A-3> 3gt
noremap <silent> <A-4> 4gt
noremap <silent> <A-5> 5gt
noremap <silent> <A-6> 6gt
noremap <silent> <A-7> 7gt
noremap <silent> <A-8> 8gt
noremap <silent> <A-9> :tablast<CR>

" Buffer handles
noremap <silent> zz :b#<CR>

" Coc.nvim
source ~/.config/nvim/.vimrc_keymap_coc_nvim
