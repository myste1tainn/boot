#################### File util snips
snippet direxist "Description" b
if _, err := os.Stat($1); !os.IsNotExist(err) {
	return $2
}
endsnippet
#################### Error snips
snippet ifep "If error then print" b
if err != nil {
	fmt.Println(err)
}
endsnippet

snippet ifel "If error then print" b
if err != nil {
	log.Fatalf("Error: %v", err)
}
endsnippet

snippet ifepr "If error then print return" b
if err != nil {
	fmt.Println(err)
	return
}
endsnippet

snippet ifelr "If error then log return" b
if err != nil {
	log.Fatalf("Error: %v", err)
	return
}
endsnippet

#################### Conversion Snips
snippet convself "Function loops to extract property of self" b
func (this $1) $2() $3 {
    var res $3
    for _, v := range ${4:this}$5 {
        res = append(res, $6)
    }
    return res
}
endsnippet
snippet convarr "Function loops for array conversion from & to" b
func to$1(items []$2) []$3 {
	var res []$3
	for _, v := range items {
		res = append(res, $3{$4})
	}
	return res
}
endsnippet

