" autocmd FileType javascriptreact setlocal indentexpr=GetJsxIndent()

" set leader key to ,
let g:mapleader=","

" Save everytime text changed
autocmd TextChanged,TextChangedI <buffer> if filereadable(expand('%')) | silent write | endif

" For vimdiff
noremap <leader>gd <Esc>:Gvdiff!<CR>
noremap gdl :diffget LOCAL<CR>
noremap gdr :diffget REMOTE<CR>
noremap gd2 :diffget //2<CR>
noremap gd3 :diffget //3<CR>

" movement
map <silent> <A-[> <C-w><C-w>
map <silent> <A-]> <C-w>W

"" Commands
" close all buffers except the current one
command! BufCurOnly execute '%bdelete!|edit#|bdelete!#'
" Get location of this file
command! WhereIsThis execute 'echo expand("%")'
