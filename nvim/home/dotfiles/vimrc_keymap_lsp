" >> Lsp key bindings
nnoremap <silent> gd     <cmd>lua vim.lsp.buf.definition()<CR>
nnoremap <silent> gD     <cmd>lua vim.lsp.buf.declaration()<CR>
nnoremap <silent> gr     <cmd>lua vim.lsp.buf.references()<CR>
nnoremap <silent> gi     <cmd>lua vim.lsp.buf.implementation()<CR>
nnoremap <silent> <F1>   <cmd>Lspsaga hover_doc<CR>
nnoremap <silent> <C-k>  <cmd>lua vim.lsp.buf.signature_help()<CR>
nnoremap <silent> <C-p>  <cmd>Lspsaga diagnostic_jump_prev<CR>
nnoremap <silent> <C-n>  <cmd>Lspsaga diagnostic_jump_next<CR>
nnoremap <silent> gs     <cmd>Lspsaga signature_help<CR>

nnoremap <silent> <F2>   :Lspsaga diagnostic_jump_next<CR>
nnoremap <silent> <F14>  :Lspsaga diagnostic_jump_prev<CR>
noremap  <silent> <F18>  <ESC>:Lspsaga rename<CR>
noremap  <silent> <F13>  <ESC>:Lspsaga signature_help<CR>
nnoremap <silent> <A-CR> :TryCodeAction<CR>
vnoremap <silent> <A-CR> :TryCodeAction<CR>
inoremap <silent> <A-CR> <ESC>:TryCodeAction<CR>
nnoremap <silent> <A-L>  <cmd>lua vim.lsp.buf.formatting()<CR>

" movement
map <silent> <A-[> <C-w><C-w>
map <silent> <A-]> <C-w>W
" nmap <C-space> <ESC>:call Terminal()<CR>


command! -range TryCodeAction call TryCodeAction(<range>,<line1>,<line2>)
function! TryCodeAction(r,l1,l2) abort
    if a:r == 0
        execute 'Lspsaga code_action'
    else
        execute 'Lspsaga range_code_action'
    endif
endfunction
