" basic settings
syntax on
set number
set relativenumber
set ignorecase      " ignore case
set smartcase     " but don't ignore it, when search string contains uppercase letters
"set nocompatible
set incsearch        " do incremental searching
set visualbell
set expandtab
set tabstop=4
set noruler
set noshowcmd
set shiftwidth=4
set hlsearch
set virtualedit=all
set backspace=indent,eol,start " allow backspacing over everything in insert mode
set autoindent
set cindent
set smartindent
set cinkeys=0{,0},0),:,0#,!^F,o,O,e
set indentkeys=o,O,*<Return>,<>>,<<>,/,{,},0],0)
set mouse=a  " mouse support
" set switchbuf=newtab " when 'Switching' buffer use existing tab if target buffer already opened somewhere, newtab otherwise
set splitbelow

" autocmd FileType typescript setlocal indentexpr=GetTypescriptIndent()
" autocmd FileType javascript setlocal indentexpr=GetJavascriptIndent()
