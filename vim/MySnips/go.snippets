snippet hexroutehealth "Hexagonal 'health' route" b
func bindHealthRoute(a app.App) {
	a.Register(
		app.AppMethodGET,
		"/health",
		nextfnd.HealthHandler(),
	)
}
endsnippet

snippet apn "Normal append routine" b
${1:arr} = append(${1:}, ${2:v})
endsnippet

snippet itoa "strconv.Itoa(#)" i
strconv.Itoa(${0:${VISUAL:variable}})
endsnippet

snippet debug "l.Debugf('# = %v', #)" i
l.Debugf("${0:${VISUAL:variable}} = %v", ${0:${VISUAL:variable}})
endsnippet

#################### Test snips
snippet testcase "New test case object definition"
type given struct {
}
type when struct {
}
type expect struct {
}

type testCase struct {
	name string
	given given
	when when
	expect expect
}

testCases := []testCase{
}

for _, tc := range testCases {
	t.Run(tc.name, func (t *testing.T) {
		sut := ${1:service}.${2:New}$3
		actual, actualErr := ${4:sut.Execute(${5:})}
	})
}
endsnippet

snippet newmock "Creating new typed structure" b
type mock$1 struct {
	*mock.Mock
}

func new${1/\w+/\u$0/g}() ${2:port.}$1 {
	return newMock${1/\w+/\u$0/g}
}

func newMock${1/\w+/\u$0/g}() *mock$1 {
	return &$1{
		Mock: &mock.Mock{},
	}
}
endsnippet
