" autocmd TermOpen * noremap <C-space> <ESC>:call Terminal()<CR>

function! Terminal()

    for i in  range(1, bufnr('$'))
        let foundBufId = v:null
        let foundBufI = -1
        let bufid = bufwinid(l:i)
        " echom "Got bufid = ".l:bufid
        if l:bufid == -1 
            continue
        endif

        let buftype = getbufvar(l:i, '&buftype', 'ERROR')
        " echom "Buftype = ".l:buftype
        if l:buftype == "ERROR"
            " echom "Cannot get buffer type for bufid = ".l:bufid
            continue
        elseif l:buftype ==# 'terminal'
            let foundBufId = l:bufid
            let foundBufI = l:i
            break
        else
            continue
        endif
    endfor

    if l:foundBufId != v:null
        " :10split +terminal
        execute 'bdelete! '.l:foundBufI
    else
        " :10split +terminal
        "
        execute '10split +terminal'
    endif

endfunction

