# Snippets for Go

priority -50

snippet ctxtimeout "Create context with timeout" b
${1:ctx}, ${2:cancel} := context.WithTimeout(${3:context.Background()}, ${4:10}*${5:time.Second})
defer $2()
endsnippet

snippet testsuitegiven "Create a test suite 'given' supporting class" b
type given struct {
	request ${1:sutPackageName}.${2:SutParameterType}
	rctx    *nextfnd.RouteContext
	l       *log.Logger
}

func NewGiven() *given {
	return &given{}
}

func (given *given) validRequest() *given {
	given.request = ${1:sutPackageName}.${2:SutParameterType}{
	}
	given.rctx = &nextfnd.RouteContext{}
	given.l = log.L
	return given
}
endsnippet

snippet testsuitewhen "Create a test suite 'when' supproting class" b
type when struct {
	given *given

	$1Response *$1.Response
	$1Port *$1.Mock
}

func NewWhen(given *given) *when {
	return &when{
		given:           given,
		$1Response:      &$1.Response{},
		$1Port:   $1.NewMock(),
	}
}
endsnippet

snippet testsuiteexpect "Create a test suite 'expect, supporting class" b
type expect struct {
	given *given
	when  *when

	response *confirm.Response
	err      nexterr.NextError
}

func NewExpect(given *given, when *when) *expect {
	return &expect{
		given:    given,
		when:     when,
		response: nil,
		err:      nil,
	}
}

func (expect *expect) responseOk() *confirm.Response {
	return &confirm.Response{
		BppTxnRef:           expect.when.confirmTxn.BppTxnRef,
		ChannelTxnRef:       nextutils.StringNotNil(expect.when.confirmTxn.ChannelTxnRef),
		TransactionDateTime: expect.when.confirmTxn.TransactionDateTime,
	}
}
endsnippet

snippet testsuitecls "Create a test suite supporting class" b
type ${1:ClassName}${2:FuncName}TestSuite struct {
	suite.Suite

	sut ${3:sutPackageName}.${4:SutType}

	given  *given
	when   *when
	expect *expect
}

func (suite *${1:ClassName}${2:FuncName}TestSuite) Init() {
	suite.given = NewGiven()
	suite.when = NewWhen(suite.given)
	suite.expect = NewExpect(suite.given, suite.when)
	suite.sut = NewSut(suite.when)
}

func NewSut(context *when) ${3:sutPackageName}.${4:SutType} {
	return ${3:sutPackageName}.New(
		$5
	)
}
endsnippet

################## BEGIN Testing Suite function
snippet testsuite "Create a test suite package" b
func Test${1:ClassName}${2:FuncName}TestSuite(t *testing.T) {
	suite.Run(t, new(${1/\w+/\l$0/g}${2:FuncName}TestSuite))
}

func (suite *${1/\w+/\l$0/g}${2:FuncName}TestSuite) SetupTest() {
	suite.Init()
}

func (suite *${1/\w+/\l$0/g}${2:FuncName}TestSuite) TeardownTest() {
}

func (suite *${1/\w+/\l$0/g}${2:FuncName}TestSuite) Test${2:FuncName}_ValidRequest_AllGreen() {
	suite.given.
		validRequest()
	suite.when.
		requestIsSomething()

	actualResp, actualErr := suite.sut.${2:FuncName}(suite.given.request, suite.given.rctx, suite.given.l)

	assert.Equal(suite.T(), suite.expect.responseOk(), actualResp)
}
endsnippet
#################### END Testing function

